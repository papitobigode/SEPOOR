<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Rectangle?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="360.0" style="-fx-background-color: #1e3a8a;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ResetPasswordController">

   <VBox alignment="BOTTOM_CENTER" prefHeight="250.0" spacing="10.0">
      <Text fill="#d1d5db" text="SEPOOR">
         <font><Font name="System Bold" size="36.0" /></font>
      </Text>
      <Rectangle fill="#f59e0b" height="120.0" width="200.0" arcHeight="20" arcWidth="20" />
   </VBox>

   <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 30 30 0 0;" VBox.vgrow="ALWAYS">
      <padding>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </padding>
      
      <Text text="Reset Password">
         <font><Font name="System Bold" size="18.0" /></font>
      </Text>
      
      <Text fill="gray" text="Silakan masukkan password baru" />

      <PasswordField fx:id="newPasswordField" promptText="PASSWORD BARU" style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-pref-height: 45;" />

      <PasswordField fx:id="confirmPasswordField" promptText="KONFIRMASI PASSWORD" style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-pref-height: 45;" />

      <Button mnemonicParsing="false" onAction="#handleResetPassword" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #0077b6; -fx-background-radius: 10; -fx-cursor: hand;" text="RESET PASSWORD" textFill="WHITE">
         <font><Font name="System Bold" size="14.0" /></font>
      </Button>

      <HBox alignment="CENTER" spacing="5">
         <Text text="Kembali ke" />
         <Hyperlink text="Halaman Login" textFill="#1e3a8a" style="-fx-font-weight: bold;" onAction="#handleBackToLogin"/>
      </HBox>

   </VBox>
</VBox>