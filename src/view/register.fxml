<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Rectangle?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="360.0" style="-fx-background-color: #1e3a8a;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RegisterController">

   <VBox alignment="BOTTOM_CENTER" prefHeight="250.0" spacing="10.0">
      <Text fill="#d1d5db" text="SEPOOR">
         <font><Font name="System Bold" size="36.0" /></font>
      </Text>
      <Rectangle fill="#f59e0b" height="120.0" width="200.0" arcHeight="20" arcWidth="20" />
   </VBox>

   <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 30 30 0 0;" VBox.vgrow="ALWAYS">
      <padding>
         <Insets bottom="30.0" left="30.0" right="30.0" top="40.0" />
      </padding>
      
      <Text text="DAFTAR">
         <font><Font name="System Bold" size="20.0" /></font>
      </Text>
      
      <VBox prefHeight="10" />

      <TextField fx:id="usernameField" promptText="USERNAME" style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-pref-height: 45;" />

      <javafx.scene.layout.StackPane alignment="CENTER_RIGHT">
         
         <TextField fx:id="passwordVisibleField" promptText="PASSWORD" visible="false" managed="false" style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-pref-height: 45;" />
         
         <PasswordField fx:id="passwordField" promptText="PASSWORD" style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-pref-height: 45;" />

         <Button onAction="#togglePasswordVisibility" text="👁" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: gray; -fx-font-size: 16px;">
            <padding><Insets right="10"/></padding>
         </Button>
         
      </javafx.scene.layout.StackPane>

      <Button mnemonicParsing="false" onAction="#handleRegister" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #0077b6; -fx-background-radius: 10; -fx-cursor: hand;" text="DAFTAR" textFill="WHITE">
         <font><Font name="System Bold" size="14.0" /></font>
      </Button>

      <HBox alignment="CENTER" spacing="5">
         <Text text="Sudah punya akun?" />
         <Hyperlink text="Masuk" textFill="#1e3a8a" style="-fx-font-weight: bold;" onAction="#handleToLogin"/>
      </HBox>

   </VBox>
</VBox>