<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?> <?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="700.0" prefWidth="360.0" style="-fx-background-color: #1e3a8a;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BookingController">

   <top>
       <HBox alignment="CENTER_LEFT">
           <padding>
               <Insets top="20" right="20" bottom="20" left="20"/>
           </padding>
           <Button text="← Kembali" textFill="WHITE" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-cursor: hand;" onAction="#handleBack"/>
       </HBox>
   </top>

   <center>
      <VBox alignment="CENTER" spacing="20.0">
         <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
         </padding>
         
         <VBox alignment="CENTER" spacing="5">
             <Text fill="WHITE" text="SEPOOR">
                 <font><Font name="System Bold" size="24.0" /></font>
             </Text>
             <Text fill="WHITE" text="Mau ke mana hari ini?">
                 <font><Font size="14.0" /></font>
             </Text>
         </VBox>

         <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);" spacing="15">
             <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
             </padding>
             
             <VBox spacing="5">
                 <Label text="Keberangkatan" textFill="GRAY" style="-fx-font-size: 12px;"/>
                 <HBox alignment="CENTER_LEFT" spacing="10">
                     <Text text="🚉" style="-fx-font-size: 20px;"/>
                     <TextField fx:id="inputAsal" promptText="Pilih stasiun asal" editable="false" 
                             onMouseClicked="#handlePilihAsal" 
                             prefWidth="250" style="-fx-background-color: transparent; -fx-border-color: #e5e7eb; -fx-border-radius: 5; -fx-cursor: hand;"/>
                 </HBox>
             </VBox>

             <StackPane>
                 <Line endX="250" stroke="#e5e7eb" />
                 <Button text="⇅" onAction="#handleSwap" style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 50; -fx-cursor: hand; -fx-text-fill: #1e3a8a;"/>
             </StackPane>

             <VBox spacing="5">
                 <Label text="Tujuan" textFill="GRAY" style="-fx-font-size: 12px;"/>
                 <HBox alignment="CENTER_LEFT" spacing="10">
                     <Text text="🏁" style="-fx-font-size: 20px;"/>
                     <TextField fx:id="inputTujuan" promptText="Pilih stasiun tujuan" editable="false" 
                             onMouseClicked="#handlePilihTujuan"
                             prefWidth="250" style="-fx-background-color: transparent; -fx-border-color: #e5e7eb; -fx-border-radius: 5; -fx-cursor: hand;"/>
                 </HBox>
             </VBox>

             <VBox spacing="5">
                 <Label text="Tanggal Berangkat" textFill="GRAY" style="-fx-font-size: 12px;"/>
                 <DatePicker fx:id="inputTanggal" promptText="Pilih Tanggal" prefWidth="280" style="-fx-background-color: transparent;"/>
             </VBox>

             <Label fx:id="errorLabel" text="Tidak dapat memilih stasiun dengan keberangkatan dan tujuan yang sama" 
                 textFill="#ef4444" visible="false" managed="false" wrapText="true" textAlignment="CENTER">
                 <font><Font size="12.0"/></font>
                 <VBox.margin><Insets bottom="5.0" /></VBox.margin>
             </Label>

             <Button fx:id="btnCari" text="Cari Kereta" onAction="#handleCari" prefWidth="280" prefHeight="45" style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;">
                 <font><Font size="16.0"/></font>
             </Button>

         </VBox>
      </VBox>
   </center>
</BorderPane>
