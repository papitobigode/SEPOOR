<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="700.0" prefWidth="360.0" style="-fx-background-color: #1e3a8a;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ProfileController">

   <center>
      <VBox alignment="CENTER" spacing="20.0">
         
         <StackPane onMouseClicked="#handleChangePhoto" style="-fx-cursor: hand;" maxWidth="130.0" maxHeight="130.0">
            
            <Circle fx:id="profileCircle" fill="LIGHTGRAY" radius="60.0" stroke="WHITE" strokeType="INSIDE" strokeWidth="3.0">
               <effect>
                  <DropShadow color="rgba(0,0,0,0.2)" radius="10" />
               </effect>
            </Circle>
            
            <StackPane alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: white; -fx-background-radius: 50; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 5, 0, 0, 1);" StackPane.alignment="BOTTOM_RIGHT">
               
               <Text text="📷" style="-fx-font-size: 18px;" boundsType="VISUAL" textOrigin="CENTER" />
               
               <StackPane.margin>
                  <Insets bottom="5.0" right="5.0" /> 
               </StackPane.margin>
            </StackPane>
         </StackPane>

         <Label fx:id="usernameLabel" text="Username" textFill="WHITE">
            <font><Font name="System Bold" size="20.0" /></font>
         </Label>

         <Region prefHeight="30.0" />

         <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-cursor: hand;" text="KELUAR" textFill="#1e3a8a">
            <font><Font name="System Bold" size="14.0" /></font>
         </Button>

      </VBox>
   </center>

   <bottom>
      <HBox alignment="CENTER" prefHeight="80.0" spacing="40.0" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, -5);">
         
         <VBox alignment="CENTER" onMouseClicked="#handleMenuBeranda" spacing="2" style="-fx-cursor: hand;">
            <Text fill="gray" style="-fx-font-size: 24px;" text="🏠" />
            <Text fill="gray" style="-fx-font-size: 10px;" text="Beranda" />
         </VBox>

         <VBox alignment="CENTER" onMouseClicked="#handleMenuTiket" spacing="2" style="-fx-cursor: hand;">
            <Text fill="gray" style="-fx-font-size: 24px;" text="🎫" />
            <Text fill="gray" style="-fx-font-size: 10px;" text="Tiket Saya" />
         </VBox>

         <VBox alignment="CENTER" onMouseClicked="#handleMenuProfil" spacing="2" style="-fx-cursor: hand;">
            <Text fill="#1e3a8a" style="-fx-font-size: 24px;" text="👤" />
            <Text fill="#1e3a8a" style="-fx-font-size: 10px; -fx-font-weight: bold;" text="Profil" />
         </VBox>

      </HBox>
   </bottom>

</BorderPane>