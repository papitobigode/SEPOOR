<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="360.0" style="-fx-background-color: #1e3a8a;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">

   <VBox alignment="BOTTOM_CENTER" prefHeight="250.0" spacing="10.0">
      <padding>
         <Insets bottom="20.0" />
      </padding>
      
      <Text fill="#d1d5db" text="SEPOOR">
         <font>
            <Font name="System Bold" size="36.0" />
         </font>
      </Text>
      
      <Rectangle arcHeight="20.0" arcWidth="20.0" fill="#f59e0b" height="120.0" width="200.0" />
   </VBox>

   <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 30 30 0 0;" VBox.vgrow="ALWAYS">
      <padding>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </padding>
      
      <Text text="Selamat Datang di SEPOOR!">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Text>
      
      <Text fill="gray" text="Masuk atau Daftar sekarang! untuk menikmati fitur yang tersedia di SEPOOR" textAlignment="CENTER" wrappingWidth="280.0" />

      <VBox prefHeight="10.0" />

      <TextField fx:id="usernameField" promptText="USERNAME" style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-pref-height: 45;" />

      <VBox spacing="2.0">
         
         <StackPane alignment="CENTER_RIGHT">
            
            <TextField fx:id="passwordVisibleField" managed="false" promptText="PASSWORD" style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-pref-height: 45;" visible="false" />
            
            <PasswordField fx:id="passwordField" promptText="PASSWORD" style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-pref-height: 45;" />

            <Button onAction="#togglePasswordVisibility" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: gray; -fx-font-size: 16px;" text="👁">
               <padding>
                  <Insets right="10.0" />
               </padding>
            </Button>
            
         </StackPane>

         <Hyperlink onAction="#handleForgotPassword" text="Lupa password?" textFill="#1e3a8a">
             <font>
               <Font name="System Bold" size="11.0" />
            </font>
         </Hyperlink>
      </VBox>

      <Button mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #0077b6; -fx-background-radius: 10; -fx-cursor: hand;" text="MASUK" textFill="WHITE">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>

      <HBox alignment="CENTER" spacing="5.0">
         <Text text="Belum punya akun?" />
         <Hyperlink onAction="#handleToRegister" style="-fx-font-weight: bold;" text="Daftar Sekarang" textFill="#1e3a8a" />
      </HBox>

   </VBox>
</VBox>