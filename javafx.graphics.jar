/* Styling Global */
.root {
    -fx-font-family: 'Segoe UI', sans-serif;
}

/* Tulisan SEPOOR di atas */
.title-logo {
    -fx-font-size: 36px;
    -fx-font-weight: bold;
    -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);
}

/* Kartu Putih Melengkung */
.bottom-card {
    -fx-background-color: white;
    /* Melengkung hanya di kiri atas dan kanan atas */
    -fx-background-radius: 40 40 0 0; 
    -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, -5);
}

/* Text Header (Selamat Datang...) */
.header-text {
    -fx-font-size: 18px;
    -fx-font-weight: bold;
    -fx-text-fill: #000000;
}

/* Text Penjelasan */
.sub-text {
    -fx-font-size: 12px;
    -fx-text-fill: #666666;
}

/* Input Box (Abu-abu rounded) */
.input-field {
    -fx-background-color: #dcdcdc; /* Warna abu-abu */
    -fx-background-radius: 10;
    -fx-padding: 12px;
    -fx-font-size: 12px;
    -fx-font-weight: bold;
    -fx-prompt-text-fill: #888888;
}

.input-field:focused {
    -fx-background-color: #ffffff;
    -fx-border-color: #007acc;
    -fx-border-radius: 10;
}

/* Tombol Biru Besar */
.primary-button {
    -fx-background-color: #0077b6; /* Warna Biru Laut */
    -fx-text-fill: white;
    -fx-font-size: 16px;
    -fx-font-weight: bold;
    -fx-background-radius: 20;
    -fx-padding: 10px;
    -fx-cursor: hand;
}

.primary-button:hover {
    -fx-background-color: #0096c7;
}

/* Link Daftar Sekarang */
.link-text {
    -fx-text-fill: #1a237e;
    -fx-font-weight: bold;
    -fx-border-color: transparent;
    -fx-padding: 0;
}