<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="360.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.SelectStationController">

    <top>
        <VBox spacing="10" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <padding>
                <Insets top="20" right="20" bottom="15" left="20"/>
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="←" onAction="#handleBack" style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand;"/>
                <Label text="Pilih Stasiun">
                    <font><Font name="System Bold" size="18.0"/></font>
                </Label>
            </HBox>
            
            <TextField fx:id="searchField" promptText="Cari stasiun atau kota..." style="-fx-background-color: #f3f4f6; -fx-background-radius: 10; -fx-padding: 10;"/>
        </VBox>
    </top>

    <center>
        <ListView fx:id="stationListView" style="-fx-background-color: white; -fx-border-color: transparent;"/>
    </center>

</BorderPane>